# Activate the production profile when deploying.
SPRING_PROFILES_ACTIVE=prod

# Core database
KFARMS_DB_URL=jdbc:postgresql://db-host:5432/kfarms_db
KFARMS_DB_USERNAME=replace-me
KFARMS_DB_PASSWORD=replace-me

# Frontend / auth
# For the recommended same-origin deploy, this is the single public app URL.
KFARMS_FRONTEND_BASE_URL=https://app.example.com
KFARMS_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
KFARMS_COOKIE_SECURE=true
# Same-origin deploy: keep `Lax` and leave the cookie domain empty.
# Split frontend/backend subdomains: change to `None` and `.example.com`.
KFARMS_COOKIE_SAMESITE=Lax
KFARMS_COOKIE_DOMAIN=

# CORS
KFARMS_CORS_ALLOWED_ORIGINS=https://app.example.com
# Optional wildcard support for subdomains:
# KFARMS_CORS_ALLOWED_ORIGIN_PATTERNS=https://*.example.com

# Mail
KFARMS_SMTP_HOST=smtp.gmail.com
KFARMS_SMTP_PORT=587
KFARMS_SMTP_USERNAME=replace-me
KFARMS_SMTP_PASSWORD=replace-me

# Optional integrations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
KFARMS_PAYSTACK_ENABLED=false
KFARMS_PAYSTACK_SECRET_KEY=
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
